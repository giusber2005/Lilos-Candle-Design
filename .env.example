# ─── Database ─────────────────────────────────────────────────────────────────
# Percorso del file SQLite (creato automaticamente da pnpm db:push)
DATABASE_URL=dev.db

# ─── Admin dashboard ──────────────────────────────────────────────────────────
ADMIN_PASSWORD=changeme123
JWT_SECRET=cambia-questa-chiave-segreta

# ─── Stripe (pagamenti online) ────────────────────────────────────────────────
# Lascia vuoto per testare il sito senza pagamenti
# Ottieni le chiavi su https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Chiave pubblica Stripe (usata nel frontend)
VITE_STRIPE_PUBLISHABLE_KEY=

# ─── GitHub Issues (notifiche ordini — opzionale) ─────────────────────────────
# Crea un token su https://github.com/settings/tokens con scope "repo"
GITHUB_TOKEN=
GITHUB_REPO=tuousername/tuorepo

# ─── Porte (solo sviluppo locale) ─────────────────────────────────────────────
API_PORT=3001
