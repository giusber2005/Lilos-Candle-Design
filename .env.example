# ─── Database ─────────────────────────────────────────────────────────────────
# Locale: usa un file SQLite (nessuna installazione necessaria)
DATABASE_URL=file:dev.db

# Produzione (Turso — SQLite hosted gratuito)
# 1. Vai su https://turso.tech e crea un account
# 2. turso db create liloscandle
# 3. turso db show liloscandle --url  →  DATABASE_URL
# 4. turso db tokens create liloscandle  →  DATABASE_AUTH_TOKEN
# DATABASE_URL=libsql://liloscandle-xxx.turso.io
# DATABASE_AUTH_TOKEN=eyJ...

# ─── Admin dashboard ──────────────────────────────────────────────────────────
ADMIN_PASSWORD=changeme123
JWT_SECRET=cambia-questa-chiave-segreta

# ─── Stripe (pagamenti online) ────────────────────────────────────────────────
# Lascia vuoto per testare il sito senza pagamenti
# Ottieni le chiavi su https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Chiave pubblica Stripe (usata nel frontend)
VITE_STRIPE_PUBLISHABLE_KEY=

# ─── GitHub Issues (notifiche ordini — opzionale) ─────────────────────────────
# Crea un token su https://github.com/settings/tokens con scope "repo"
GITHUB_TOKEN=
GITHUB_REPO=tuousername/tuorepo

# ─── Porte (solo sviluppo locale) ─────────────────────────────────────────────
API_PORT=3001
